{
  "extends": "@vue/tsconfig/tsconfig.json",
  "include": ["src/renderer/env.d.ts", "src/renderer/src/**/*", "src/renderer/src/**/*.vue"],
  "exclude": ["src/renderer/src/**/__tests__/*"],
  "compilerOptions": {
    "lib": ["ES2022", "DOM"],
    "target": "es2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "composite": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/renderer/src/*"]
    },
    "types": ["naive-ui/volar", "@intlify/unplugin-vue-i18n/messages", "unplugin-icons/types/vue"],
    "esModuleInterop": true,
    "jsx": "preserve",
    "skipLibCheck": true,
    "resolveJsonModule": true
  }
}
